{
  "expo": {
    "name": "Club_Chat",
    "slug": "Club_Chat",
    "owner": "parks3131",
    "scheme": "clubchat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.parkstechusa.clubchat"
    },
    "android": {
      "package": "com.parkstechusa.clubchat",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      [
        "expo-image-picker",
        {
          "photosPermission": "ClubChat uses your photo library to set your profile picture.",
          "cameraPermission": "ClubChat uses your camera to let you take and share photos in chat."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "18982e70-f36a-4df6-a816-dc0d87b2dbb5"
      }
    }
  }
}
